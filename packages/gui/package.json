{
  "name": "@docmirror/dev-sidecar-gui",
  "version": "2.1.4",
  "private": false,
  "description": "给开发者的加速代理工具图形界面",
  "author": {
    "email": "xiaojunnuo@qq.com",
    "name": "Greper"
  },
  "license": "MPL-2.0",
  "homepage": "https://github.com/docmirror/dev-sidecar",
  "scripts": {
    "preelectron:build": "cross-env CXXFLAGS=-std=c++17 CL=/std:c++17 electron-builder install-app-deps && node scripts/clean-native-artifacts.js",
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "electron:build": "vue-cli-service electron:build",
    "electron": "vue-cli-service electron:serve",
    "postinstall": "node scripts/download-xray.js",
    "electron:icons": "electron-icon-builder --input=./public/logo/win.png --output=build --flatten",
    "electron:icons-mac": "electron-icon-builder --input=./public/logo/mac.png --output=build --flatten",
    "electron:icons-black": "electron-icon-builder --input=./public/logo/win-black.png --output=build/black --flatten"
  },
  "dependencies": {
    "@docmirror/dev-sidecar": "workspace:*",
    "@docmirror/mitmproxy": "workspace:*",
    "@starknt/shutdown-handler-napi": "^0.0.3",
    "@starknt/sysproxy": "^0.0.3",
    "@vscode/sudo-prompt": "^9.3.2",
    "adm-zip": "^0.5.17",
    "ant-design-vue": "^4.2.6",
    "archiver": "^7.0.1",
    "better-sqlite3": "12.10.0",
    "bindings": "^1.5.0",
    "core-js": "^3.49.0",
    "electron-baidu-tongji": "^1.0.5",
    "electron-updater": "^6.8.3",
    "file-uri-to-path": "^1.0.0",
    "json5": "^2.2.3",
    "lodash": "^4.18.1",
    "minimist": "^1.2.8",
    "path-browserify": "^1.0.1",
    "request-progress": "^3.0.0",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "tiny-emitter": "^2.1.0",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4",
    "vue3-json-editor": "^1.1.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@vue/babel-helper-vue-jsx-merge-props": "^1.4.0",
    "@vue/babel-preset-jsx": "^1.4.0",
    "@vue/cli-plugin-babel": "^5.0.9",
    "@vue/cli-service": "^5.0.9",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^19.1.9",
    "electron-builder": "^25.1.8",
    "electron-icon-builder": "^2.0.1",
    "json5-loader": "^4.0.1",
