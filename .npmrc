shamefully-hoist=true
phantomjs_cdnurl=https://npmmirror.com/mirrors/phantomjs
registry=https://registry.npmmirror.com
# @atomlong scope always resolves from the public npm registry, even when
# CI sets the global registry to npm.pkg.github.com via setup-node.
@atomlong:registry=https://registry.npmjs.org/
# Native modules (e.g. @parcel/watcher) require C++17.
# Do not put shell `export ...` statements in .npmrc; npm/pnpm treat them as
# invalid config keys. Build scripts and CI should pass CXXFLAGS/CL via the
# actual process environment instead.
